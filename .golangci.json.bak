{
  "version": "2",
  "linters": {
    "default": "fast",
    "disable": [
      "unused",
      "lll",
      "wsl",
      "cyclop",
      "gocognit",
      "funlen",
      "nakedret",
      "wsl_v5"
    ],
    "enable": [
      "tagalign"
    ],
    "settings": {
      "depguard": {
        "rules": {
          "main": {
            "list-mode": "lax",
            "allow": [
              "**"
            ]
          }
        }
      },
      "tagalign": {
        "align": true,
        "sort": true,
        "strict": true
      },
      "wsl_v5": {
        "allow-first-in-block": true,
        "allow-whole-block": false,
        "branch-max-lines": 2
      }
    }
  },
  "formatters": {
    "enable": [
      "gofmt",
      "goimports",
      "gci",
      "golines",
      "swaggo"
    ],
    "settings": {
      "gci": {
        "sections": [
          "standard",
          "default"
        ]
      },
      "golines": {
        "max-len": 1024,
        "tab-len": 4,
        "shorten-comments": false,
        "reformat-tags": true,
        "chain-split-dots": true
      }
    },
    "exclusions": {
      "warn-unused": true,
      "generated": "strict",
      "paths": []
    }
  }
}
